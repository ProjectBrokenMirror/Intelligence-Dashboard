# Copy to .env on the server (same directory as docker-compose.yml). Docker Compose reads this file automatically.

# Public API base URL for the browser — exactly ONE URL, no commas, no trailing slash.
VITE_API_URL=https://api.example.com

# Comma-separated list of web app origins allowed to call the API (CORS).
CORS_ORIGINS=https://app.example.com
