# Copy to .env on the server (same directory as docker-compose.yml). Docker Compose reads this file automatically.

# Database password for user "pv". MUST match what Postgres was initialized with.
# If you change this after the first `docker compose up`, the old data volume still has the old password —
# either set this back to the original value, or remove the pgdata volume and start fresh (loses DB data).
# Use letters/numbers only if possible (special characters can break the URL).
POSTGRES_PASSWORD=pv

# Public API base URL for the browser — exactly ONE URL, no commas, no trailing slash.
VITE_API_URL=https://api.example.com

# Comma-separated list of web app origins allowed to call the API (CORS).
CORS_ORIGINS=https://app.example.com
